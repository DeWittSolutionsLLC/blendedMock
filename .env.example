# Set to true to intercept all API calls with MSW mock data (no real keys needed)
VITE_MOCK_API=false

# uEngage Edge API (ordering, menu, catalogue)
VITE_UENGAGE_EDGE_URL=https://api.uengage.in/edge

# uEngage Prism API (loyalty, CRM, wallet)
VITE_UENGAGE_PRISM_URL=https://api.uengage.in/prism

# Shared API key — never commit your real key; copy this file to .env.local
VITE_UENGAGE_API_KEY=your_api_key_here
